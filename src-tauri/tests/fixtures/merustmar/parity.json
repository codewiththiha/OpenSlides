    "code": "a == b != c <= d >= e && f || g\nx < y > z + 1 - 2 * 3 / 4 % 5 = 6",
    "dark": "<span class=\"line\"><span style=\"color:#abb2bf\">a </span><span style=\"color:#56b6c2\">==</span><span style=\"color:#abb2bf\"> b </span><span style=\"color:#56b6c2\">!=</span><span style=\"color:#abb2bf\"> c </span><span style=\"color:#56b6c2\">&lt;=</span><span style=\"color:#abb2bf\"> d </span><span style=\"color:#56b6c2\">&gt;=</span><span style=\"color:#abb2bf\"> e </span><span style=\"color:#56b6c2\">&amp;&amp;</span><span style=\"color:#abb2bf\"> f </span><span style=\"color:#56b6c2\">||</span><span style=\"color:#abb2bf\"> g</span></span>\n<span class=\"line\"><span style=\"color:#abb2bf\">x </span><span style=\"color:#56b6c2\">&lt;</span><span style=\"color:#abb2bf\"> y </span><span style=\"color:#56b6c2\">&gt;</span><span style=\"color:#abb2bf\"> z </span><span style=\"color:#56b6c2\">+</span><span style=\"color:#abb2bf\"> </span><span style=\"color:#d19a66\">1</span><span style=\"color:#abb2bf\"> </span><span style=\"color:#56b6c2\">-</span><span style=\"color:#abb2bf\"> </span><span style=\"color:#d19a66\">2</span><span style=\"color:#abb2bf\"> </span><span style=\"color:#56b6c2\">*</span><span style=\"color:#abb2bf\"> </span><span style=\"color:#d19a66\">3</span><span style=\"color:#abb2bf\"> </span><span style=\"color:#56b6c2\">/</span><span style=\"color:#abb2bf\"> </span><span style=\"color:#d19a66\">4</span><span style=\"color:#abb2bf\"> </span><span style=\"color:#56b6c2\">%</span><span style=\"color:#abb2bf\"> </span><span style=\"color:#d19a66\">5</span><span style=\"color:#abb2bf\"> </span><span style=\"color:#56b6c2\">=</span><span style=\"color:#abb2bf\"> </span><span style=\"color:#d19a66\">6</span></span>",
    "light": "<span class=\"line\"><span style=\"color:#383a42\">a </span><span style=\"color:#0184bc\">==</span><span style=\"color:#383a42\"> b </span><span style=\"color:#0184bc\">!=</span><span style=\"color:#383a42\"> c </span><span style=\"color:#0184bc\">&lt;=</span><span style=\"color:#383a42\"> d </span><span style=\"color:#0184bc\">&gt;=</span><span style=\"color:#383a42\"> e </span><span style=\"color:#0184bc\">&amp;&amp;</span><span style=\"color:#383a42\"> f </span><span style=\"color:#0184bc\">||</span><span style=\"color:#383a42\"> g</span></span>\n<span class=\"line\"><span style=\"color:#383a42\">x </span><span style=\"color:#0184bc\">&lt;</span><span style=\"color:#383a42\"> y </span><span style=\"color:#0184bc\">&gt;</span><span style=\"color:#383a42\"> z </span><span style=\"color:#0184bc\">+</span><span style=\"color:#383a42\"> </span><span style=\"color:#986801\">1</span><span style=\"color:#383a42\"> </span><span style=\"color:#0184bc\">-</span><span style=\"color:#383a42\"> </span><span style=\"color:#986801\">2</span><span style=\"color:#383a42\"> </span><span style=\"color:#0184bc\">*</span><span style=\"color:#383a42\"> </span><span style=\"color:#986801\">3</span><span style=\"color:#383a42\"> </span><span style=\"color:#0184bc\">/</span><span style=\"color:#383a42\"> </span><span style=\"color:#986801\">4</span><span style=\"color:#383a42\"> </span><span style=\"color:#0184bc\">%</span><span style=\"color:#383a42\"> </span><span style=\"color:#986801\">5</span><span style=\"color:#383a42\"> </span><span style=\"color:#0184bc\">=</span><span style=\"color:#383a42\"> </span><span style=\"color:#986801\">6</span></span>"
